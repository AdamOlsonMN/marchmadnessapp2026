# Host Nginx config for HTTPS on mm.adamolson.org.
# Use on the VPS (not inside Docker). Docker web service should map 8080:80 so this can use 80/443.
#
# 1. Copy to /etc/nginx/sites-available/mm.adamolson.org (or conf.d/).
# 2. Replace YOUR_VPS_PUBLIC_IP with your server IP for the redirect server if desired.
# 3. Run: sudo certbot certonly --webroot -w /var/www/certbot -d mm.adamolson.org
# 4. Enable: sudo ln -s /etc/nginx/sites-available/mm.adamolson.org /etc/nginx/sites-enabled/
# 5. Reload: sudo nginx -t && sudo systemctl reload nginx
#
# In docker-compose.yml, change web ports to "8080:80" so host Nginx can bind 80/443.

server {
    listen 80;
    listen [::]:80;
    server_name mm.adamolson.org;
    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name mm.adamolson.org;

    ssl_certificate     /etc/letsencrypt/live/mm.adamolson.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mm.adamolson.org/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
